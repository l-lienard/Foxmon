<Window x:Class="Foxmon.CombatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FoxMon - Combat" Height="550" Width="900"
        Background="#1a1a2e"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Zone combat -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Joueur -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="NomJoueur" FontSize="20" FontWeight="Bold"
                           Foreground="#CC44FF" HorizontalAlignment="Center"/>

                <TextBlock x:Name="EmojiJoueur" FontSize="64" Margin="0,10">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="TransformJoueur"/>
                    </TextBlock.RenderTransform>
                </TextBlock>

                <TextBlock x:Name="TypeJoueur" Foreground="LightGray"/>
                <ProgressBar x:Name="PVJoueur" Width="200" Height="20"
                             Foreground="#44FF44" Background="#2a2a4e" Maximum="100"/>
                <TextBlock x:Name="PVJoueurText" Foreground="White"/>
            </StackPanel>

            <!-- VS -->
            <TextBlock Grid.ColumnSpan="2" Text="⚡ VS ⚡"
                       FontSize="32" Foreground="Yellow"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Ennemi -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="NomEnnemi" FontSize="20" FontWeight="Bold"
                           Foreground="#FF4444"/>

                <TextBlock x:Name="EmojiEnnemi" FontSize="64" Margin="0,10">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="TransformEnnemi"/>
                    </TextBlock.RenderTransform>
                </TextBlock>

                <TextBlock x:Name="TypeEnnemi" Foreground="LightGray"/>
                <ProgressBar x:Name="PVEnnemi" Width="200" Height="20"
                             Foreground="#FF4444" Background="#2a2a4e" Maximum="100"/>
                <TextBlock x:Name="PVEnnemiText" Foreground="White"/>
            </StackPanel>
        </Grid>

        <!-- Log -->
        <Border Grid.Row="1" Background="#0d0d1e" CornerRadius="10"
                BorderBrush="#CC44FF" BorderThickness="2" Padding="10">
            <TextBlock x:Name="LogCombat" Foreground="White" TextWrapping="Wrap"/>
        </Border>

        <!-- Attaques -->
        <WrapPanel x:Name="AttaquesPanel" Grid.Row="2" HorizontalAlignment="Center"/>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="BtnCapturer" Content="🎯 CAPTURER"
                    Width="180" Height="45" Margin="10"
                    Click="BtnCapturer_Click"/>

            <Button x:Name="BtnFuir" Content="🏃 FUIR"
                    Width="180" Height="45" Margin="10"
                    Click="BtnFuir_Click"/>
        </StackPanel>
    </Grid>
</Window>